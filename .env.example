# ==============================================================================
# Environment Configuration Example
# Copy this file to '.env' and fill in your values.
# ==============================================================================

# Core Django Settings
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True #use False in production

# Database Settings (Local / Docker Compose)
# Note: These are used when DATABASE_URL is not set.
DB_NAME=testapp_db
DB_USER=admin
DB_PASSWORD=password
DB_HOST=db
DB_PORT=5432

# Database Settings (Render / Neon / Production)
# If DATABASE_URL is set, Django will prioritize this over individual DB_* variables.
# Format: postgres://username:password@hostname:port/database_name?sslmode=require
DATABASE_URL=postgres://testflow_owner:your_password@ep-cool-name-123456.us-east-2.aws.neon.tech/testflow?sslmode=require

# Cache / Redis Settings
# Local Docker Compose defaults to redis://redis:6379/0
# Production Render Key-Value uses your Internal Redis URL (e.g., redis://red-abc123xyz:6379)
REDIS_URL=redis://redis:6379/0

# Google OAuth Settings (Sign in with Google)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email Verification (OTP Sending via Gmail)
# Note: For Gmail, SENDER_PASSWORD must be a 16-character App Password, not your regular password.
SENDER_EMAIL=your-gmail-address@gmail.com
SENDER_PASSWORD=your-gmail-app-password

# ImageKit Settings (For Client-side Image Uploads)
IMAGEKIT_PUBLIC_KEY=public_your_public_key
IMAGEKIT_PRIVATE_KEY=private_your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint_id
